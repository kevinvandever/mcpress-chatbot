OPENAI_API_KEY=your-openai-api-key-here
CHROMA_PERSIST_DIR=./chroma_db
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# --- Appstle Subscription Authentication ---
# Base URL for the Appstle subscription management API
APPSTLE_API_URL=https://subscription-admin.appstle.com

# API key for authenticating with the Appstle API (X-API-Key header)
APPSTLE_API_KEY=your-appstle-api-key-here

# URL where users can purchase/renew a subscription (shown on login denial)
SUBSCRIPTION_SIGNUP_URL=https://your-store.com/subscribe

# Secret key for signing JWT tokens (used by both admin and customer auth)
JWT_SECRET_KEY=your-jwt-secret-key-here
