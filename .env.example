# --- Appstle Subscription Authentication ---
# Base URL for the Appstle subscription management API
APPSTLE_API_URL=https://subscription-admin.appstle.com

# API key for authenticating with the Appstle API (X-API-Key header)
APPSTLE_API_KEY=your-appstle-api-key-here

# URL where users can purchase/renew a subscription (shown on login denial)
SUBSCRIPTION_SIGNUP_URL=https://your-store.com/subscribe

# --- Freemium Usage Gate ---
# Maximum number of free questions per anonymous user before requiring subscription (default: 5)
FREE_QUESTION_LIMIT=5

# --- Subscription Tag Patterns (comma-separated, case-insensitive) ---
# Customer tags that indicate an active subscription
SUBSCRIPTION_TAG_ACTIVE=appstle_subscription_active_customer
# Customer tags that indicate a paused subscription
SUBSCRIPTION_TAG_PAUSED=appstle_subscription_paused_customer
# Customer tags that indicate an inactive/cancelled subscription
SUBSCRIPTION_TAG_INACTIVE=appstle_subscription_inactive_customer

# Secret key for signing JWT tokens (used by both admin and customer auth)
JWT_SECRET_KEY=your-jwt-secret-key-here

# --- Email Service Configuration (for password reset) ---
# SMTP server hostname for sending password reset emails
EMAIL_SMTP_HOST=smtp.example.com

# SMTP server port (587 for TLS, 465 for SSL)
EMAIL_SMTP_PORT=587

# Sender email address for password reset emails
EMAIL_FROM_ADDRESS=noreply@example.com

# SMTP authentication password
EMAIL_SMTP_PASSWORD=your-smtp-password

# Frontend base URL used to construct password reset links
FRONTEND_URL=https://mc-chatmaster.netlify.app
